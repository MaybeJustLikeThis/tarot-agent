[
  {
    "id": "minor_cups_01",
    "name_cn": "圣杯Ace",
    "name_en": "Ace of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 1,
    "upright_keywords": ["新感情", "情感开启", "爱", "直觉", "创造力"],
    "reversed_keywords": ["情感封闭", "压抑感情", "空虚", "冷漠"],
    "upright_meaning": "新的情感开始、爱情降临、情感充沛、直觉敏锐、内心的喜悦。圣杯Ace代表情感的满溢和新感情的萌芽。",
    "reversed_meaning": "情感封闭、压抑真实感受、感到空虚和冷漠。可能因为恐惧而关闭了自己的心门。",
    "image_file": "cups-01.png"
  },
  {
    "id": "minor_cups_02",
    "name_cn": "圣杯二",
    "name_en": "Two of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 2,
    "upright_keywords": ["爱情", "和谐", "平等", "结合", "伙伴关系"],
    "reversed_keywords": ["关系失衡", "分离", "误解", "不和谐"],
    "upright_meaning": "爱情、和谐的关系、平等的结合、深层连接。圣杯二代表两个人之间的深度连接和情感共鸣。",
    "reversed_meaning": "关系失衡、误解、分离、不和谐。可能两人之间存在沟通障碍或价值观差异。",
    "image_file": "cups-02.png"
  },
  {
    "id": "minor_cups_03",
    "name_cn": "圣杯三",
    "name_en": "Three of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 3,
    "upright_keywords": ["庆祝", "友谊", "欢乐", "聚会", "共享喜悦"],
    "reversed_keywords": ["孤立", "友谊破裂", "过度放纵", "疏远"],
    "upright_meaning": "庆祝、友谊、欢乐的聚会、共享美好时光。圣杯三代表与朋友共度的快乐时刻和集体庆祝。",
    "reversed_meaning": "孤立、友谊出现裂痕、过度放纵。可能感到与朋友疏远或在社交中过度消耗。",
    "image_file": "cups-03.png"
  },
  {
    "id": "minor_cups_04",
    "name_cn": "圣杯四",
    "name_en": "Four of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 4,
    "upright_keywords": ["冷漠", "不满", "忽视机会", "冥想", "内省"],
    "reversed_keywords": ["走出冷漠", "重新投入", "抓住机会", "觉醒"],
    "upright_meaning": "冷漠、不满现状、对新机会视而不见、需要内省。圣杯四提醒你可能正在忽略身边已经存在的好机会。",
    "reversed_meaning": "走出冷漠、重新投入生活、抓住新的机会。你开始意识到之前忽略的美好，愿意重新敞开心扉。",
    "image_file": "cups-04.png"
  },
  {
    "id": "minor_cups_05",
    "name_cn": "圣杯五",
    "name_en": "Five of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 5,
    "upright_keywords": ["悲伤", "失落", "遗憾", "哀悼", "关注失去"],
    "reversed_keywords": ["接受", "走出悲伤", "重建", "看到希望"],
    "upright_meaning": "悲伤、失落、遗憾、哀悼过去。圣杯五代表情感上的痛苦，但提醒你还有剩下的杯子是满的——并非一切都已失去。",
    "reversed_meaning": "接受失去、走出悲伤、开始重建。你正在慢慢接受过去，愿意向前看。",
    "image_file": "cups-05.png"
  },
  {
    "id": "minor_cups_06",
    "name_cn": "圣杯六",
    "name_en": "Six of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 6,
    "upright_keywords": ["怀旧", "童年", "纯真", "回忆", "重聚"],
    "reversed_keywords": ["沉溺过去", "不切实际", "需要放手", "成长"],
    "upright_meaning": "怀旧、童年记忆、纯真无邪、美好的回忆。圣杯六带你回到过去的温暖时光，但也提醒你珍惜当下。",
    "reversed_meaning": "过度沉溺过去、不切实际、需要放手才能成长。可能过于留恋过去而无法面对现在。",
    "image_file": "cups-06.png"
  },
  {
    "id": "minor_cups_07",
    "name_cn": "圣杯七",
    "name_en": "Seven of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 7,
    "upright_keywords": ["幻想", "选择", "白日梦", "迷惑", "可能性"],
    "reversed_keywords": ["清醒", "做出选择", "脚踏实地", "摆脱幻觉"],
    "upright_meaning": "幻想、众多选择、白日梦、迷惑不定。圣杯七代表面对许多可能性时的困惑，需要分辨现实与幻想。",
    "reversed_meaning": "清醒过来、做出明确选择、脚踏实地。你开始摆脱幻想，面对现实做出决定。",
    "image_file": "cups-07.png"
  },
  {
    "id": "minor_cups_08",
    "name_cn": "圣杯八",
    "name_en": "Eight of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 8,
    "upright_keywords": ["离开", "寻找更深意义", "放弃", "精神探索", "转变"],
    "reversed_keywords": ["停滞", "恐惧改变", "逃避", "无法放手"],
    "upright_meaning": "主动离开、寻求更深层的意义、放弃不再满足的东西。圣杯八代表为了追求更高的精神满足而选择离开舒适区。",
    "reversed_meaning": "停滞不前、恐惧改变、逃避必要的放手。你可能害怕离开熟悉的环境或关系。",
    "image_file": "cups-08.png"
  },
  {
    "id": "minor_cups_09",
    "name_cn": "圣杯九",
    "name_en": "Nine of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 9,
    "upright_keywords": ["满足", "愿望成真", "幸福", "享受", "满足感"],
    "reversed_keywords": ["不满足", "贪婪", "表面满足", "内心空虚"],
    "upright_meaning": "满足、愿望成真、幸福、享受生活。圣杯九被称为「愿望牌」，代表内心的满足和愿望的实现。",
    "reversed_meaning": "不满足、贪得无厌、表面满足但内心空虚。可能得到了想要的却不感到快乐。",
    "image_file": "cups-09.png"
  },
  {
    "id": "minor_cups_10",
    "name_cn": "圣杯十",
    "name_en": "Ten of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 10,
    "upright_keywords": ["家庭幸福", "和谐", "圆满", "情感满足", "归属"],
    "reversed_keywords": ["家庭不和", "情感断裂", "理想破灭", "疏离"],
    "upright_meaning": "家庭幸福、和谐美满、情感圆满、归属感。圣杯十是幸福之牌，代表情感生活的完满和家庭的温馨。",
    "reversed_meaning": "家庭不和睦、情感断裂、理想破灭。可能家庭或亲密关系中存在未解决的矛盾。",
    "image_file": "cups-10.png"
  },
  {
    "id": "minor_cups_11",
    "name_cn": "圣杯侍从",
    "name_en": "Page of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 11,
    "upright_keywords": ["敏感", "直觉", "新消息", "创意", "梦幻"],
    "reversed_keywords": ["情绪不稳", "不成熟", "逃避现实", "过度敏感"],
    "upright_meaning": "敏感、直觉敏锐、情感上的新消息、创意灵感。圣杯侍从代表内心深处的直觉信息，需要用心倾听。",
    "reversed_meaning": "情绪不稳定、情感不成熟、逃避现实。可能过于沉浸在自己的情绪世界中。",
    "image_file": "cups-11.png"
  },
  {
    "id": "minor_cups_12",
    "name_cn": "圣杯骑士",
    "name_en": "Knight of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 12,
    "upright_keywords": ["浪漫", "邀请", "理想主义", "温柔", "追求"],
    "reversed_keywords": ["不切实际", "情感不稳", "逃避", "过于理想化"],
    "upright_meaning": "浪漫、温柔的邀请、理想主义、追求美好。圣杯骑士是浪漫的信使，带来爱的邀请和美好的承诺。",
    "reversed_meaning": "不切实际、情感不稳定、过于理想化。可能沉浸在浪漫幻想中而忽视现实。",
    "image_file": "cups-12.png"
  },
  {
    "id": "minor_cups_13",
    "name_cn": "圣杯王后",
    "name_en": "Queen of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 13,
    "upright_keywords": ["慈悲", "直觉", "情感智慧", "关怀", "敏感"],
    "reversed_keywords": ["情感依赖", "不安全感", "情绪化", "自我牺牲"],
    "upright_meaning": "慈悲、深刻的直觉、情感智慧、温暖的关怀。圣杯王后代表情感成熟和直觉的智慧，善于感受他人情绪。",
    "reversed_meaning": "情感过度依赖、不安全感、情绪化。可能因为过于在意他人感受而忽略了自己的需要。",
    "image_file": "cups-13.png"
  },
  {
    "id": "minor_cups_14",
    "name_cn": "圣杯国王",
    "name_en": "King of Cups",
    "arcana": "minor",
    "suit": "cups",
    "number": 14,
    "upright_keywords": ["情感平衡", "智慧", "外交", "冷静", "宽容"],
    "reversed_keywords": ["情感操控", "情绪压抑", "虚伪", "内心矛盾"],
    "upright_meaning": "情感平衡、智慧、外交手腕、冷静而富有同情心。圣杯国王代表情感上的成熟和内在的平静。",
    "reversed_meaning": "情感操控、压抑情绪、内心矛盾。可能表面平静但内心波涛汹涌。",
    "image_file": "cups-14.png"
  }
]
