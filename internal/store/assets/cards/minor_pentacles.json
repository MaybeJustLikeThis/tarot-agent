[
  {
    "id": "minor_pentacles_01",
    "name_cn": "星币Ace",
    "name_en": "Ace of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 1,
    "upright_keywords": ["新财务机会", "繁荣", "新开始", "安全", "显化"],
    "reversed_keywords": ["财务损失", "错失机会", "计划失败", "缺乏规划"],
    "upright_meaning": "新的财务机会、繁荣的开始、安全感的建立、愿望显化。星币Ace代表物质层面新机遇的到来，是播种的好时机。",
    "reversed_meaning": "财务损失、错失良机、计划未能落地。可能因为准备不足或时机不对而错过了机会。",
    "image_file": "pentacles-01.png"
  },
  {
    "id": "minor_pentacles_02",
    "name_cn": "星币二",
    "name_en": "Two of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 2,
    "upright_keywords": ["平衡", "调整", "灵活", "优先级", "多任务"],
    "reversed_keywords": ["失衡", "资源分配不当", "应接不暇", "混乱"],
    "upright_meaning": "平衡多个优先事项、灵活调整、在变化中保持节奏。星币二代表需要在多个方面之间找到平衡。",
    "reversed_meaning": "失衡、资源分配不当、应接不暇。可能同时处理太多事情而无法兼顾。",
    "image_file": "pentacles-02.png"
  },
  {
    "id": "minor_pentacles_03",
    "name_cn": "星币三",
    "name_en": "Three of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 3,
    "upright_keywords": ["团队合作", "精通", "学习", "建设", "认可"],
    "reversed_keywords": ["缺乏合作", "质量低劣", "缺乏投入", "孤独工作"],
    "upright_meaning": "团队合作、技能提升、学习与建设、获得认可。星币三代表通过合作和学习来打造卓越的成果。",
    "reversed_meaning": "缺乏合作精神、工作质量不佳、投入不足。可能缺乏团队支持或自己不够用心。",
    "image_file": "pentacles-03.png"
  },
  {
    "id": "minor_pentacles_04",
    "name_cn": "星币四",
    "name_en": "Four of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 4,
    "upright_keywords": ["守财", "安全", "控制", "保守", "囤积"],
    "reversed_keywords": ["慷慨", "放手", "打破束缚", "冒险"],
    "upright_meaning": "守财、追求安全感、控制欲、保守的态度。星币四提醒你过度紧抓不放反而可能阻碍了增长。",
    "reversed_meaning": "变得慷慨、学会放手、打破保守的束缚。你开始愿意分享和冒险，不再死守安全感。",
    "image_file": "pentacles-04.png"
  },
  {
    "id": "minor_pentacles_05",
    "name_cn": "星币五",
    "name_en": "Five of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 5,
    "upright_keywords": ["困境", "贫穷", "孤独", "困难", "健康问题"],
    "reversed_keywords": ["恢复", "走出困境", "接受帮助", "精神觉醒"],
    "upright_meaning": "财务困境、贫穷感、被排斥的孤独、健康问题。星币五代表物质和精神上的匮乏，但提醒你帮助就在附近。",
    "reversed_meaning": "走出困境、接受帮助、开始恢复。你正在慢慢摆脱困境，愿意接受他人的支持。",
    "image_file": "pentacles-05.png"
  },
  {
    "id": "minor_pentacles_06",
    "name_cn": "星币六",
    "name_en": "Six of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 6,
    "upright_keywords": ["慷慨", "施与受", "慈善", "分享", "平衡"],
    "reversed_keywords": ["自私", "债务", "不公平", "一方付出过多"],
    "upright_meaning": "慷慨、施与受的平衡、慈善、分享财富。星币六代表财富的流动和慷慨的品质。",
    "reversed_meaning": "自私、债务问题、施与受的失衡。可能在关系中一方付出过多而另一方不够。",
    "image_file": "pentacles-06.png"
  },
  {
    "id": "minor_pentacles_07",
    "name_cn": "星币七",
    "name_en": "Seven of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 7,
    "upright_keywords": ["耐心", "评估", "等待收获", "投入", "长远眼光"],
    "reversed_keywords": ["急躁", "投入不足", "收获不佳", "方向错误"],
    "upright_meaning": "耐心等待、评估进展、投入后的等待收获。星币七代表你已经付出了努力，现在需要耐心等待成果。",
    "reversed_meaning": "缺乏耐心、投入不够或方向不对。可能急于求成或之前的努力没有回报。",
    "image_file": "pentacles-07.png"
  },
  {
    "id": "minor_pentacles_08",
    "name_cn": "星币八",
    "name_en": "Eight of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 8,
    "upright_keywords": ["勤奋", "专注", "精通", "学徒", "重复练习"],
    "reversed_keywords": ["缺乏投入", "完美主义", "不专注", "敷衍了事"],
    "upright_meaning": "勤奋工作、专注于提升技能、追求精通、不断练习。星币八代表通过持续的努力和练习来精进技艺。",
    "reversed_meaning": "缺乏投入、完美主义反而阻碍进步、敷衍了事。可能不愿付出必要的努力或过于追求完美。",
    "image_file": "pentacles-08.png"
  },
  {
    "id": "minor_pentacles_09",
    "name_cn": "星币九",
    "name_en": "Nine of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 9,
    "upright_keywords": ["富足", "独立", "优雅", "自给自足", "享受成果"],
    "reversed_keywords": ["过度依赖", "财务不稳", "缺乏规划", "失去品味"],
    "upright_meaning": "物质富足、独立自主、优雅从容、享受自己的劳动成果。星币九代表通过自己的努力获得了丰足的生活。",
    "reversed_meaning": "过度依赖他人、财务不稳定、缺乏长远规划。可能没有管理好自己努力获得的成果。",
    "image_file": "pentacles-09.png"
  },
  {
    "id": "minor_pentacles_10",
    "name_cn": "星币十",
    "name_en": "Ten of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 10,
    "upright_keywords": ["传承", "家族财富", "稳定", "长期成功", "根基"],
    "reversed_keywords": ["财务问题", "家族不和", "失去根基", "短视"],
    "upright_meaning": "家族传承、世代财富、长期稳定、根基深厚。星币十代表通过长期积累获得的物质安全感和家族的稳固。",
    "reversed_meaning": "财务问题、家族矛盾、失去根基。可能家族或长期积累的资产出现了问题。",
    "image_file": "pentacles-10.png"
  },
  {
    "id": "minor_pentacles_11",
    "name_cn": "星币侍从",
    "name_en": "Page of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 11,
    "upright_keywords": ["学习", "新技能", "务实", "学生", "目标"],
    "reversed_keywords": ["缺乏方向", "不切实际", "拖延", "缺乏动力"],
    "upright_meaning": "学习新技能、务实的目标、脚踏实地的新开始。星币侍从代表对学习和成长的渴望，愿意从基础做起。",
    "reversed_meaning": "缺乏方向、不切实际、拖延懒散。可能对学习或工作缺乏热情和动力。",
    "image_file": "pentacles-11.png"
  },
  {
    "id": "minor_pentacles_12",
    "name_cn": "星币骑士",
    "name_en": "Knight of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 12,
    "upright_keywords": ["勤奋", "可靠", "常规", "踏实", "忠诚"],
    "reversed_keywords": ["懒惰", "固执", "不愿改变", "机械重复"],
    "upright_meaning": "勤勉踏实、可靠、遵循常规、忠诚坚定。星币骑士代表稳定而持久的努力，一步一个脚印地前进。",
    "reversed_meaning": "懒散、固执己见、不愿改变、机械地重复。可能过于固执而无法适应变化。",
    "image_file": "pentacles-12.png"
  },
  {
    "id": "minor_pentacles_13",
    "name_cn": "星币王后",
    "name_en": "Queen of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 13,
    "upright_keywords": ["富足", "滋养", "务实", "安全感", "大地能量"],
    "reversed_keywords": ["自私", "物质主义", "工作与生活失衡", "忽视健康"],
    "upright_meaning": "物质富足、温暖的滋养、务实可靠、创造舒适的环境。星币王后代表善于管理资源并营造温馨氛围。",
    "reversed_meaning": "过度物质主义、自私、工作与生活失衡。可能过于追求物质而忽视了情感和健康。",
    "image_file": "pentacles-13.png"
  },
  {
    "id": "minor_pentacles_14",
    "name_cn": "星币国王",
    "name_en": "King of Pentacles",
    "arcana": "minor",
    "suit": "pentacles",
    "number": 14,
    "upright_keywords": ["财富", "成功", "商业头脑", "安全", "奢华"],
    "reversed_keywords": ["贪婪", "腐败", "放纵", "财务失控"],
    "upright_meaning": "财富和成功、出色的商业头脑、安全稳定、享受优质生活。星币国王代表物质世界的巅峰成就。",
    "reversed_meaning": "贪婪、腐败、过度放纵、财务失控。可能因为对财富和享乐的追求而失去了平衡。",
    "image_file": "pentacles-14.png"
  }
]
