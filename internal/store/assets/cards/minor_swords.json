[
  {
    "id": "minor_swords_01",
    "name_cn": "宝剑Ace",
    "name_en": "Ace of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 1,
    "upright_keywords": ["突破", "清晰", "真理", "正义", "新思维"],
    "reversed_keywords": ["混乱", "不公", "缺乏清晰", "判断失误"],
    "upright_meaning": "突破性的思维、清晰的判断、追求真理、正义的力量。宝剑Ace代表思想的突破和理性的力量，鼓励你果断行动。",
    "reversed_meaning": "思维混乱、判断失误、缺乏清晰的洞察力。可能被偏见或错误信息所迷惑。",
    "image_file": "swords-01.png"
  },
  {
    "id": "minor_swords_02",
    "name_cn": "宝剑二",
    "name_en": "Two of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 2,
    "upright_keywords": ["僵局", "犹豫", "平衡", "避免选择", "蒙蔽"],
    "reversed_keywords": ["做出决定", "打破僵局", "真相揭露", "不再逃避"],
    "upright_meaning": "僵局、难以抉择、内心的矛盾、蒙蔽双眼不愿面对。宝剑二代表你需要做出艰难的选择，但一直在回避。",
    "reversed_meaning": "做出决定、打破僵局、不再逃避。你终于面对了之前回避的问题，做出了选择。",
    "image_file": "swords-02.png"
  },
  {
    "id": "minor_swords_03",
    "name_cn": "宝剑三",
    "name_en": "Three of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 3,
    "upright_keywords": ["心碎", "悲伤", "痛苦", "分离", "背叛"],
    "reversed_keywords": ["疗愈", "走出痛苦", "释放悲伤", "恢复"],
    "upright_meaning": "心碎、深切的悲伤、痛苦的分离、背叛。宝剑三是一张悲伤之牌，代表情感上的深刻痛苦，但这也是疗愈的开始。",
    "reversed_meaning": "疗愈中、走出痛苦的阴影、释放悲伤。你正在从心碎中慢慢恢复。",
    "image_file": "swords-03.png"
  },
  {
    "id": "minor_swords_04",
    "name_cn": "宝剑四",
    "name_en": "Four of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 4,
    "upright_keywords": ["休息", "恢复", "冥想", "退隐", "疗愈"],
    "reversed_keywords": ["不安", "焦虑", "无法休息", "仓促行动"],
    "upright_meaning": "休息、恢复精力、冥想、暂时退隐。宝剑四提醒你需要停下来休息和恢复，不要急于行动。",
    "reversed_meaning": "焦虑不安、无法安静下来、仓促行事。可能身体或心理需要休息但你不愿停下来。",
    "image_file": "swords-04.png"
  },
  {
    "id": "minor_swords_05",
    "name_cn": "宝剑五",
    "name_en": "Five of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 5,
    "upright_keywords": ["失败", "损失", "空虚的胜利", "背叛", "冲突"],
    "reversed_keywords": ["和解", "走出失败", "反思", "弥补"],
    "upright_meaning": "失败、损失、空虚的胜利、背叛与冲突。宝剑五提醒你即使赢了也可能失去更多，真正的胜利不是打败别人。",
    "reversed_meaning": "和解、走出失败的阴影、反思后弥补。你开始从过去的冲突中吸取教训，寻求和解。",
    "image_file": "swords-05.png"
  },
  {
    "id": "minor_swords_06",
    "name_cn": "宝剑六",
    "name_en": "Six of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 6,
    "upright_keywords": ["过渡", "旅行", "离开困境", "改变", "寻找平静"],
    "reversed_keywords": ["受阻", "不愿离开", "反复", "过渡困难"],
    "upright_meaning": "过渡期、旅行、离开困境走向平静、转变。宝剑六代表从困难中走出，正在向更好的方向移动。",
    "reversed_meaning": "过渡受阻、不愿离开舒适区、反复不定。可能难以接受必要的改变。",
    "image_file": "swords-06.png"
  },
  {
    "id": "minor_swords_07",
    "name_cn": "宝剑七",
    "name_en": "Seven of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 7,
    "upright_keywords": ["欺骗", "策略", "背弃", "隐蔽", "不诚实"],
    "reversed_keywords": ["坦白", "放下策略", "面对真相", "道歉"],
    "upright_meaning": "欺骗、策略、偷偷摸摸、不诚实的行为。宝剑七警告有人在暗中进行不光彩的事情，或你自己在隐瞒什么。",
    "reversed_meaning": "坦白真相、放下策略、面对现实。你准备坦诚面对之前隐瞒或逃避的事情。",
    "image_file": "swords-07.png"
  },
  {
    "id": "minor_swords_08",
    "name_cn": "宝剑八",
    "name_en": "Eight of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 8,
    "upright_keywords": ["束缚", "限制", "恐惧", "被困", "自我设限"],
    "reversed_keywords": ["释放", "看清真相", "突破限制", "自我解放"],
    "upright_meaning": "感到被困、受限、恐惧阻碍了行动、自我设限。宝剑八揭示你感到被困住，但很多束缚其实来自自己的恐惧。",
    "reversed_meaning": "释放束缚、看清真实情况、突破自我限制。你开始意识到困住你的只是幻象。",
    "image_file": "swords-08.png"
  },
  {
    "id": "minor_swords_09",
    "name_cn": "宝剑九",
    "name_en": "Nine of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 9,
    "upright_keywords": ["焦虑", "噩梦", "担忧", "内心痛苦", "失眠"],
    "reversed_keywords": ["释放焦虑", "面对恐惧", "噩梦结束", "恢复平静"],
    "upright_meaning": "深度焦虑、噩梦、过度担忧、内心煎熬。宝剑九代表被恐惧和担忧所困扰，但很多恐惧可能只是想象的。",
    "reversed_meaning": "焦虑减轻、面对恐惧、噩梦结束。你正在走出焦虑的阴影，恢复内心的平静。",
    "image_file": "swords-09.png"
  },
  {
    "id": "minor_swords_10",
    "name_cn": "宝剑十",
    "name_en": "Ten of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 10,
    "upright_keywords": ["终结", "最低谷", "背叛", "痛苦结束", "重生"],
    "reversed_keywords": ["避免终结", "延迟结束", "缓慢恢复", "抗拒放下"],
    "upright_meaning": "痛苦的终结、跌入谷底、彻底的结束。宝剑十代表最艰难的时刻已经到来，但从这里开始只会向上走。",
    "reversed_meaning": "避免必然的终结、延迟痛苦的结束、缓慢恢复。你可能在拖延一个必要的结束。",
    "image_file": "swords-10.png"
  },
  {
    "id": "minor_swords_11",
    "name_cn": "宝剑侍从",
    "name_en": "Page of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 11,
    "upright_keywords": ["好奇", "警觉", "新想法", "沟通", "观察"],
    "reversed_keywords": ["八卦", "言语伤人", "缺乏沟通", "多疑"],
    "upright_meaning": "好奇心强、警觉、新思想的萌芽、善于观察。宝剑侍从代表求知欲和敏锐的观察力，善于发现隐藏的信息。",
    "reversed_meaning": "八卦、言语不当、沟通障碍、过于多疑。可能在信息传播中不够谨慎或过度猜疑。",
    "image_file": "swords-11.png"
  },
  {
    "id": "minor_swords_12",
    "name_cn": "宝剑骑士",
    "name_en": "Knight of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 12,
    "upright_keywords": ["快速行动", "果敢", "直言不讳", "雄心", "锋利"],
    "reversed_keywords": ["鲁莽", "好斗", "冲动", "缺乏计划"],
    "upright_meaning": "快速行动、果敢决断、直言不讳、雄心勃勃。宝剑骑士代表迅速果断的行动，追求真理和正义。",
    "reversed_meaning": "鲁莽冲动、好斗、缺乏考虑的行动。可能因为过于急切而做出不智之举。",
    "image_file": "swords-12.png"
  },
  {
    "id": "minor_swords_13",
    "name_cn": "宝剑王后",
    "name_en": "Queen of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 13,
    "upright_keywords": ["独立", "清晰", "公正", "理性", "敏锐"],
    "reversed_keywords": ["冷酷", "刻薄", "过度理性", "孤立"],
    "upright_meaning": "独立自主、思维清晰、公正客观、理性而有洞察力。宝剑王后代表以理性和智慧面对生活中的挑战。",
    "reversed_meaning": "过于冷酷、刻薄、过度理性而忽视情感。可能因为太过理性而显得不近人情。",
    "image_file": "swords-13.png"
  },
  {
    "id": "minor_swords_14",
    "name_cn": "宝剑国王",
    "name_en": "King of Swords",
    "arcana": "minor",
    "suit": "swords",
    "number": 14,
    "upright_keywords": ["权威", "理性", "判断力", "真相", "纪律"],
    "reversed_keywords": ["独断", "冷酷无情", "滥用权力", "偏执"],
    "upright_meaning": "权威、理性至上、出色的判断力、追求真相、严于律己。宝剑国王代表以智慧和权威处理事务。",
    "reversed_meaning": "独断专行、冷酷无情、滥用权力。可能用理性和权威压制他人，缺乏同理心。",
    "image_file": "swords-14.png"
  }
]
